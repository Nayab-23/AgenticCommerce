# Router Backend Configuration

# Arc Network
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_USDC_ADDRESS=0x0000000000000000000000000000000000000000
ARC_CHAIN_ID=1234
ARC_EXPLORER_BASE=https://testnet.arcscan.app

# Circle Programmable Wallet
CIRCLE_API_KEY=TEST_API_KEY:replace-with-circle-api-key
CIRCLE_ENTITY_SECRET_RAW=replace-with-circle-entity-secret-hex
CIRCLE_WALLET_ID=replace-with-circle-wallet-id
CIRCLE_TOKEN_ID=15dc2b5d-0994-58b0-bf8c-3a0501148ee8
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Optional legacy treasury key for local-only experiments
TREASURY_PRIVATE_KEY=replace-with-test-key-if-needed

# Provider Addresses
PROVIDER_GEMINI_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb5
PROVIDER_CLAUDE_ADDRESS=0x8626f6940E2eb28930eFb4CeF49B2d1F2C9C1199
PROVIDER_OPENAI_ADDRESS=0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0

# Provider Wrapper Endpoints
PROVIDER_GEMINI_URL=http://localhost:4001
PROVIDER_CLAUDE_URL=http://localhost:4002
PROVIDER_OPENAI_URL=http://localhost:4003

# Spending Guardrails
DAILY_SPEND_CAP_USDC=1.0
PER_REQUEST_CAP_USDC=0.02

# System Config
PORT=3000
DEMO_MODE=true
EMERGENCY_STOP=false

# Allowlist (comma-separated addresses)
PROVIDER_ALLOWLIST=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb5,0x8626f6940E2eb28930eFb4CeF49B2d1F2C9C1199,0x9fE46736679d2D9a65F0992F2272dE9f3c7fa6e0
