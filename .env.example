# Root environment notes
#
# This file intentionally contains placeholders only.
# Copy the relevant values into `router-backend/.env` and `provider-wrappers/.env`.

# Shared Arc defaults
ARC_RPC_URL=https://rpc.testnet.arc.network
ARC_EXPLORER_BASE=https://testnet.arcscan.app
ARC_USDC_ADDRESS=0x0000000000000000000000000000000000000000
ARC_CHAIN_ID=1234

# Circle programmable wallet
CIRCLE_API_KEY=TEST_API_KEY:replace-with-circle-api-key
CIRCLE_ENTITY_SECRET_RAW=replace-with-circle-entity-secret-hex
CIRCLE_WALLET_ID=replace-with-circle-wallet-id
CIRCLE_TOKEN_ID=15dc2b5d-0994-58b0-bf8c-3a0501148ee8
AGENT_WALLET_ADDRESS=0x0000000000000000000000000000000000000000

# Local provider endpoints
PROVIDER_GEMINI_URL=http://localhost:4001
PROVIDER_CLAUDE_URL=http://localhost:4002
PROVIDER_OPENAI_URL=http://localhost:4003

# Example sandbox provider addresses
PROVIDER_GEMINI_ADDRESS=0x1111111111111111111111111111111111111111
PROVIDER_CLAUDE_ADDRESS=0x2222222222222222222222222222222222222222
PROVIDER_OPENAI_ADDRESS=0x3333333333333333333333333333333333333333

# Model/API placeholders
GEMINI_API_KEY=replace-with-gemini-key
GEMINI_MODEL=gemini-1.5-flash
ANTHROPIC_API_KEY=replace-with-anthropic-key
CLAUDE_MODEL=claude-3-haiku-20240307
OPENAI_API_KEY=replace-with-openai-key
OPENAI_MODEL=gpt-3.5-turbo

# Local runtime defaults
PORT=3000
DEMO_MODE=true
EMERGENCY_STOP=false
ALLOW_UNVERIFIED_PAYMENTS=true
DAILY_SPEND_CAP_USDC=1.0
PER_REQUEST_CAP_USDC=0.02
