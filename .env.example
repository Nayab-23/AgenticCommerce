# === Router Backend ===
# Copy to router-backend/.env

# Arc Network
ARC_RPC_URL=https://rpc.arc.xyz
ARC_USDC_ADDRESS=0x1234567890123456789012345678901234567890
ARC_CHAIN_ID=1234

# Treasury Wallet (NEVER COMMIT REAL PRIVATE KEYS - This is a test key)
TREASURY_PRIVATE_KEY=0xac0974bec39a17e36ba4a6b4d238ff944bacb478cbed5efcae784d7bf4f2ff80

# Provider Addresses
PROVIDER_GEMINI_ADDRESS=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb5
PROVIDER_CLAUDE_ADDRESS=0x8626f6940E2eb28930eFb4CeF49B2d1F2C9C1199

# Provider Wrapper Endpoints
PROVIDER_GEMINI_URL=http://localhost:4001
PROVIDER_CLAUDE_URL=http://localhost:4002

# Spending Guardrails
DAILY_SPEND_CAP_USDC=1.0
PER_REQUEST_CAP_USDC=0.02

# System Config
PORT=3000
DEMO_MODE=true
EMERGENCY_STOP=false

# Allowlist (comma-separated addresses)
PROVIDER_ALLOWLIST=0x742d35Cc6634C0532925a3b844Bc9e7595f0bEb5,0x8626f6940E2eb28930eFb4CeF49B2d1F2C9C1199

# === Provider Wrappers ===
# Copy to provider-wrappers/.env

# Gemini Provider
GEMINI_PORT=4001
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL=gemini-1.5-flash

# Claude Provider
CLAUDE_PORT=4002
ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL=claude-3-haiku-20240307

# Demo Mode (uses mock responses)
DEMO_MODE=true
